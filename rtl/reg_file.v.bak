
module reg_file (
    input wire clk,
    input wire rst,
    input wire [4:0] rs_addr,
    input wire [4:0] rt_addr,
    input wire [4:0] rd_addr,
    input wire [31:0] write_data,
    input wire reg_write,
    output wire [31:0] rs_data,
    output wire [31:0] rt_data
);


reg [31:0] registers [31:0];

initial begin
    for (i = 0; i < 32; i = i + 1) registers[i] = 32'h0;
end

integer i;
// writing data if reg write and not writing to zero register
always@(negedge clk , posedge rst )begin // solving data hazard with wb stage
    if(rst) begin
        for(i = 0; i < 32; i = i + 1) begin
            registers[i] <= 32'b0;
        end
    end else
    if(reg_write && rd_addr != 0 )begin
        registers[rd_addr] <= write_data;
    end
end

//Read data happens regardless of clock or control singels
assign rs_data = rs_addr != 0 ? registers[rs_addr] : 32'b0; // zero register always reads as zero
assign rt_data = rt_addr != 0 ? registers[rt_addr] : 32'b0; 

endmodule